{
  "name": "@yukiakai/deptrace",
  "version": "1.1.2",
  "description": "Dependency auditing and upgrade planning for JavaScript and TypeScript projects.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "bin": {
    "deptrace": "dist/cli.cjs"
  },
  "scripts": {
    "test": "npm run build && npx vitest run --reporter verbose --coverage",
    "format": "prettier --write **/*.{js,ts,json}",
    "format:check": "prettier --check **/*.{js,ts,json}",
    "lint": "eslint src/**/*.ts",
    "typecheck:workspace": "tsc -p tsconfig.workspace.json",
    "build": "npx tsup",
    "docs": "npx typedoc",
    "prepare:artifact": "tsx workspace/release/prepareArtifact.ts",
    "prepare": "is-ci || husky"
  },
  "files": [
    "dist/cli.js",
    "CHANGELOG.md"
  ],
  "keywords": [
    "dependency-audit",
    "vulnerability",
    "dependency-graph",
    "supply-chain-security",
    "upgrade-planning"
  ],
  "author": "Yuki_akai",
  "homepage": "https://github.com/yukiakai212/deptrace.js",
  "funding": "https://github.com/sponsors/yukiakai212",
  "engines": {
    "node": ">= 16"
  },
  "maintainers": [
    {
      "name": "Yuki_akai",
      "homepage": "https://github.com/yukiakai212"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yukiakai212/deptrace.js.git"
  },
  "bugs": {
    "url": "https://github.com/yukiakai212/deptrace.js/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.30.1",
    "@types/lodash-es": "^4.17.12",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.0.10",
    "@types/npm-package-arg": "^6.1.4",
    "@types/npmcli__arborist": "^6.3.3",
    "@types/pacote": "^11.1.8",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.0.15",
    "@yukiakai/artifact": "^1.0.1",
    "dotenv": "^17.0.1",
    "eslint": "^9.30.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "typedoc": "^0.28.9",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@npmcli/arborist": "^9.5.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "find-up": "^8.0.0",
    "lodash-es": "^4.18.1",
    "ms": "^2.1.3",
    "npm-package-arg": "^13.0.2",
    "pacote": "^21.5.0",
    "semver": "^7.8.1",
    "zod": "^4.4.3"
  }
}
